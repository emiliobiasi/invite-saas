{
  "name": "invite-saas",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "be:dev": "bun run --cwd packages/be dev",
    "be:lint": "bun run --cwd packages/be lint",
    "be:format": "bun run --cwd packages/be format",
    "be:typecheck": "bun run --cwd packages/be typecheck",
    "be:migrate": "bun run --cwd packages/be db:migrate",
    "be:generate": "bun run --cwd packages/be db:generate"
  }
}
